    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.8.0",
